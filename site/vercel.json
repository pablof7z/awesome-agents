{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "node build-docs.mjs",
  "installCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/agents/:slug", "destination": "/agent" },
    { "source": "/agents/:slug/:tab", "destination": "/agent" }
  ],
  "headers": [
    {
      "source": "/(styles.css|app.js|agent.js|docs.js|data.js|favicon.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
