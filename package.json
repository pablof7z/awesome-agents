{
  "name": "awesome-agents",
  "version": "0.1.1",
  "description": "Install reusable agent profiles into Codex, Claude Code, and OpenCode.",
  "type": "module",
  "bin": {
    "awesome-agents": "bin/awesome-agents.js"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "scripts": {
    "changelog": "node scripts/changelog.js --write",
    "lint": "node --check bin/awesome-agents.js && node --check src/*.js && node --check scripts/*.js && node --check test/*.test.js",
    "release": "node scripts/release.js",
    "release:dry-run": "node scripts/release.js --dry-run",
    "test": "node --test"
  },
  "keywords": [
    "agents",
    "agent-profiles",
    "codex",
    "claude-code",
    "opencode",
    "cli"
  ],
  "author": "Pablo Fernandez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablof7z/awesome-agents.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  }
}
